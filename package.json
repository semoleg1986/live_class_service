{
  "name": "live_class_service",
  "version": "0.1.0",
  "private": true,
  "description": "Live class service (NestJS + mediasoup skeleton)",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "migrate:up": "npm run db:migrate",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "format": "prettier \"src/**/*.ts\" \"tests/**/*.ts\" \"*.json\" \"*.md\" --write",
    "format:check": "prettier \"src/**/*.ts\" \"tests/**/*.ts\" \"*.json\" \"*.md\" --check",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --config ./tests/unit/jest-unit.json",
    "test:integration": "jest --config ./tests/integration/jest-integration.json",
    "test:e2e": "npm run test:integration"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.2",
    "mediasoup": "^3.15.0",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.18",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^30.3.0",
    "prettier": "^3.3.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^5.7.2"
  }
}
