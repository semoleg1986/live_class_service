# live_class_service deploy profile
LIVE_CLASS_HTTP_PORT=8010
LIVE_CLASS_WS_NAMESPACE=/ws/live
LIVE_CLASS_USE_INMEMORY=1
LIVE_CLASS_MAX_STUDENTS=10
LIVE_CLASS_MAX_PARTICIPANTS=11
LIVE_CLASS_AUTH_ISSUER=auth_service
LIVE_CLASS_AUTH_AUDIENCE=platform_clients
LIVE_CLASS_AUTH_JWKS_URL=http://auth_service:8000/.well-known/jwks.json
LIVE_CLASS_REDIS_URL=redis://redis:6379/0
LIVE_CLASS_OUTBOX_STREAM=live_room.events
LIVE_CLASS_OUTBOX_BATCH_SIZE=100
LIVE_CLASS_OUTBOX_POLL_INTERVAL_MS=1000
LIVE_CLASS_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/live_class_service
LIVE_CLASS_TURN_URL=turn:__SET_TURN_HOST__:3478
LIVE_CLASS_TURN_USERNAME=__SET_IN_SECRETS__
LIVE_CLASS_TURN_PASSWORD=__SET_IN_SECRETS__
